# ─── Discord Bot ────────────────────────────────────────────────────────────
# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your application's client ID (found on the Developer Portal)
CLIENT_ID=your_client_id_here

# Your application's client secret (used for OAuth2 / dashboard login)
CLIENT_SECRET=your_client_secret_here

# Your Discord user ID (for owner-only commands)
OWNER_ID=your_discord_user_id_here

# Default command prefix for legacy prefix commands (optional)
BOT_PREFIX=!

# ─── Web Dashboard ───────────────────────────────────────────────────────────
# Port the Express dashboard server will listen on
DASHBOARD_PORT=3000

# The full URL of your dashboard (used for OAuth2 redirect)
# Development: http://localhost:3000
# Production:  https://yourdomain.com
DASHBOARD_URL=http://localhost:3000

# OAuth2 callback URL — must match exactly what's set in the Discord Developer Portal
CALLBACK_URL=http://localhost:3000/auth/discord/callback

# A long, random secret string used to sign session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_secret_string

# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB connection URI
# Local:  mongodb://localhost:27017/discord-bot
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/discord-bot
MONGODB_URI=mongodb://localhost:27017/discord-bot
