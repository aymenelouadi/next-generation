<%#
  This project was programmed by the Next Generation team.
  If you encounter any problems, open an Issue or log into the Discord server:
  https://discord.gg/BhJStSa89s

  ─────────────────────────────────────────────────────────────────────────────
  EMBED FLOW BUILDER  — Main Orchestrator
  ─────────────────────────────────────────────────────────────────────────────
  This file is intentionally thin.  All logic lives in:

    partials/embeds/
      _style.ejs         <- design-system tokens + all CSS            (~870 lines)
      _html_views.ejs    <- <main> content: list-view + builder HTML  (~207 lines)
      _html_modals.ejs   <- all modals, toast, emoji picker, data     (~170 lines)
      _js_core.ejs       <- globals, state, DOM refs, helpers, list,
                           versions/trash, editor open/close,
                           machine-state management                  (~489 lines)
      _js_canvas.ejs     <- dirty/history/undo, canvas, groups,
                           arrows, drag, pan, auto-layout            (~669 lines)
      _js_inspector.ejs  <- inspector, embed form, components,
                           transitions, permissions, triggers,
                           preview                                   (~1216 lines)
      _js_events.ejs     <- all event bindings, save, emoji picker,
                           file upload, templates, init, page JS    (~591 lines)
%>
<!DOCTYPE html>
<html lang="<%= t.lang %>" dir="<%= t.dir %>">
<head>
  <%- include('partials/head_theme') %>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= t.embeds.pageTitle %> — <%= guildInfo.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;800;900&family=Tajawal:wght@300;400;500;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <%- include('partials/embeds/_style') %>
</head>
<body>
  <div id="ov"></div>
  <canvas id="c"></canvas>
  <div class="glow glow-a"></div>
  <div class="glow glow-b"></div>

  <%- include('partials/layout', { activePage: 'embeds' }) %>

  <main class="main">
    <%- include('partials/embeds/_html_views') %>
  </main>

  <%- include('partials/embeds/_html_modals') %>

  <script src="/js/lucide.min.js"></script>
  <%- include('partials/bg_particles') %>
  <%- include('partials/embeds/_js_core') %>
  <%- include('partials/embeds/_js_canvas') %>
  <%- include('partials/embeds/_js_inspector') %>
  <%- include('partials/embeds/_js_events') %>
</body>
</html>