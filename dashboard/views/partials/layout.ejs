  }
  .gwo-sub {
    font-size: .78rem;
    color: var(--muted, rgba(203,194,255,.5));
    margin: 4px 0 0;
  }
</style>

<script>
/* ── Guild Welcome Overlay ── */
(function () {
  var ov = document.getElementById('guild-welcome-ov');
  if (!ov) return;
  /* Only show when navigated here via the Manage button */
  var gid = '<%= guildInfo.id %>';
  if (sessionStorage.getItem('cn-show-welcome') !== gid) return;
  sessionStorage.removeItem('cn-show-welcome');
  ov.style.display = 'flex';
  ov.classList.remove('gwo-hidden');

  function dismiss() {
    ov.classList.add('gwo-hidden');
    clearTimeout(timer);
    setTimeout(function () { ov.style.display = 'none'; }, 500);
  }

  var timer = setTimeout(dismiss, 2500);
  ov.addEventListener('click', dismiss, { once: true });
})();
</script>