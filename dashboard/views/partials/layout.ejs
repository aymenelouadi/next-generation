<style>
  /* ── Guild Welcome Overlay ── */
  .gwo-wrap {
    position: fixed;
    inset: 0;
    z-index: 8000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(4, 0, 16, .55);
    backdrop-filter: blur(14px) saturate(1.4);
    -webkit-backdrop-filter: blur(14px) saturate(1.4);
    opacity: 1;
    transition: opacity .5s ease;
    pointer-events: all;
  }
  .gwo-wrap.gwo-hidden {
    opacity: 0;
    pointer-events: none;
  }
  .gwo-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 40px 52px;
    background: var(--card, rgba(10,3,30,.88));
    border: 1px solid rgba(124,58,237,.25);
    border-radius: 20px;
    box-shadow: 0 24px 80px rgba(80,40,160,.35), 0 0 0 1px rgba(124,58,237,.08);
    text-align: center;
    animation: gwoIn .45s cubic-bezier(.22,1,.36,1) both;
    max-width: 340px;
    width: 90%;
  }
  @keyframes gwoIn {
    from { opacity: 0; transform: translateY(18px) scale(.96); }
    to   { opacity: 1; transform: none; }
  }
  .gwo-icon-wrap { margin-bottom: 6px; }
  .gwo-icon {
    width: 72px;
    height: 72px;
