    let _epCallback = null;
    const _epEl    = document.getElementById('emb-emoji-picker');
    const _epBody  = document.getElementById('emb-ep-body');
    const _epSearch= document.getElementById('emb-ep-search');
    let _epTab = 'unicode';

    // Render the inner HTML of an emoji-trigger button: image for custom, char for unicode, icon for empty
    function renderEmojiBtn(val) {
      if (!val) return '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>';
      if (val.startsWith('<')) return '<img src="' + resolveEmojiUrl(val) + '" alt="emoji">';
      return '<span style="font-size:1rem;line-height:1;">' + val + '</span>';
    }
    function resolveEmojiUrl(val) {
      const m = val.match(/:(\d+)>/); if (!m) return '';
      return 'https://cdn.discordapp.com/emojis/' + m[1] + '.' + (val.startsWith('<a:') ? 'gif' : 'png') + '?size=32';
    }
    function renderEpGrid(filter) {
      _epBody.innerHTML = '';
      const grid = document.createElement('div'); grid.className = 'ep-grid';
      if (_epTab === 'unicode') {
        const list = filter ? UNICODE_EMOJIS.filter(e => e.includes(filter)) : UNICODE_EMOJIS;
        list.forEach(em => { const sp = document.createElement('span'); sp.className = 'ep-emoji'; sp.textContent = em; sp.addEventListener('click', () => selectEpEmoji(em)); grid.appendChild(sp); });
      } else {
        const list = filter ? GUILD_EMOJIS.filter(e => e.name.toLowerCase().includes(filter.toLowerCase())) : GUILD_EMOJIS;
        list.forEach(em => {
          const img = document.createElement('img'); img.className = 'ep-custom';
          img.src = em.url; img.title = em.name; img.alt = em.name;
          const id = em.animated ? '<a:' + em.name + ':' + em.id + '>' : '<:' + em.name + ':' + em.id + '>';
          img.addEventListener('click', () => selectEpEmoji(id));
          grid.appendChild(img);
        });
      }
      _epBody.appendChild(grid);
    }
    function selectEpEmoji(val) { if (_epCallback) _epCallback(val); closeEmbEmojiPicker(); }
    function openEmbEmojiPicker(anchor, cb) {
      _epCallback = cb; _epTab = 'unicode'; _epSearch.value = '';
      _epEl.querySelectorAll('.ep-tab').forEach(t => t.classList.toggle('active', t.dataset.tab === 'unicode'));
      renderEpGrid('');
      _epEl.classList.add('open');
      const r = anchor.getBoundingClientRect();
      let left = r.left, top = r.bottom + 6;
      if (left + 300 > window.innerWidth - 16) left = window.innerWidth - 316;
      if (top  + 280 > window.innerHeight)     top  = Math.max(8, r.top - 288);
      _epEl.style.top = top + 'px'; _epEl.style.left = left + 'px';
      setTimeout(() => _epSearch.focus(), 40);
    }
    function closeEmbEmojiPicker() { _epEl.classList.remove('open'); _epCallback = null; }
    document.getElementById('emb-ep-close').addEventListener('click', closeEmbEmojiPicker);
    _epSearch.addEventListener('input', () => renderEpGrid(_epSearch.value));
    _epEl.querySelectorAll('.ep-tab').forEach(tab => tab.addEventListener('click', function () {
      _epTab = this.dataset.tab;
      _epEl.querySelectorAll('.ep-tab').forEach(t => t.classList.toggle('active', t === this));
      renderEpGrid(_epSearch.value);
    }));
    document.getElementById('emb-ep-ok').addEventListener('click', () => {
      const v = document.getElementById('emb-ep-manual').value.trim();
      if (v) { selectEpEmoji(v); document.getElementById('emb-ep-manual').value = ''; }
    });
    document.addEventListener('click', e => { if (!_epEl.contains(e.target) && !e.target.closest('.emoji-trigger')) closeEmbEmojiPicker(); });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        closeEmbEmojiPicker();
        $saveModal.classList.remove('open');
        $versionsModal.classList.remove('open');
        $trashModal.classList.remove('open');
        $triggersModal.classList.remove('open');
        document.getElementById('tplSaveModal').classList.remove('open');
      }
      if ((e.ctrlKey || e.metaKey) && e.key === 's' && document.getElementById('builderView').style.display !== 'none') {
        e.preventDefault();
        document.getElementById('btnSave').click();
      }
    });

    /* ════════════════════════════════════════
       FILE UPLOAD (base64 data URL)
       ════════════════════════════════════════ */
    document.addEventListener('click', e => {
      const btn = e.target.closest('.emb-upload'); if (!btn) return;
      const inp = document.createElement('input');
      inp.type = 'file'; inp.accept = 'image/*'; inp.style.display = 'none';
      document.body.appendChild(inp);
      inp.click();
      inp.addEventListener('change', () => {
        const file = inp.files[0]; if (!file) { document.body.removeChild(inp); return; }
        const reader = new FileReader();
        reader.onload = ev => {
          const idx = btn.dataset.idx;
          const el  = document.querySelector('.' + btn.dataset.target + '[data-idx="' + idx + '"]');
          if (el) { el.value = ev.target.result; syncEmbedFromDOM(+idx); renderPreview(); }
        };
        reader.readAsDataURL(file);
        document.body.removeChild(inp);
      });
    });

    /* ════════════════════════════════════════
       TEMPLATES
       ════════════════════════════════════════ */
    let savedTemplates = [];
    let _pendingTplMachine = null;

    function openTemplatesDrawer() {
      document.getElementById('templatesDrawer').classList.add('open');
      document.getElementById('tplBackdrop').classList.add('show');
      document.getElementById('templatesDrawer').removeAttribute('aria-hidden');
      loadTemplates();
    }
    function closeTemplatesDrawer() {
      document.getElementById('templatesDrawer').classList.remove('open');
      document.getElementById('tplBackdrop').classList.remove('show');
      document.getElementById('templatesDrawer').setAttribute('aria-hidden', 'true');
    }
    async function loadTemplates() {
      try {
        const r = await api('GET', '/templates');
        savedTemplates = r.data || [];
        renderTemplates();
      } catch (e) { toast(e.message || 'Failed to load templates', 'error'); }
    }
    function renderTemplates() {
      const $grid = document.getElementById('tplGrid');
      if (!savedTemplates.length) {
        $grid.innerHTML = '<div class="tpl-empty">'
          + '<div class="tpl-empty-ico"><i data-lucide="layout-template" style="width:24px;height:24px;stroke:currentColor;fill:none;"></i></div>'
          + '<p style="font-size:.82rem;font-weight:600;margin:0 0 4px;"><%= t.embeds.jsNoTpls %></p>'
          + '<p style="font-size:.75rem;margin:0;"><%= t.embeds.jsNoTplsDesc %></p>'
          + '</div>';
        lucide.createIcons();
        return;
      }
      $grid.innerHTML = savedTemplates.map(function(t) {
        const sc = t.stateCount || 1;
        const date = t.createdAt ? new Date(t.createdAt).toLocaleDateString() : '';
        return '<div class="tpl-card">'
          + '<div class="tpl-card-top">'
          + '<span class="tpl-card-name">' + esc(t.name) + '</span>'
          + '<span class="tpl-card-badge">' + sc + ' state' + (sc === 1 ? '' : 's') + '</span>'
          + '</div>'
          + (t.description ? '<p class="tpl-card-desc">' + esc(t.description) + '</p>' : '')
          + (date ? '<p class="tpl-card-date">' + date + '</p>' : '')
          + '<div class="tpl-card-acts">'
          + '<button class="btn btn-primary btn-xs btnTplApply" data-id="' + esc(t._id) + '"><i data-lucide="play" style="width:11px;height:11px;"></i> <%= t.embeds.jsApply %></button>'
          + '<button class="btn btn-ghost btn-xs btnTplExport" data-id="' + esc(t._id) + '"><i data-lucide="download" style="width:11px;height:11px;"></i> Export</button>'
          + '<button class="btn btn-danger btn-xs btnTplDel" data-id="' + esc(t._id) + '"><i data-lucide="trash-2" style="width:11px;height:11px;"></i></button>'
          + '</div>'
          + '</div>';
      }).join('');
      lucide.createIcons();
    }

    document.getElementById('tplGrid').addEventListener('click', function(e) {
      const applyBtn  = e.target.closest('.btnTplApply');
      const exportBtn = e.target.closest('.btnTplExport');
      const delBtn    = e.target.closest('.btnTplDel');
      if (applyBtn) {
        const t = savedTemplates.find(function(x) { return x._id === applyBtn.dataset.id; });
        if (!t) return;
        closeTemplatesDrawer();
        currentDoc = null; epTheme = false;
        machine = JSON.parse(JSON.stringify(t.machine));
        if (!machine.triggers) machine.triggers = [];
        $builderTitle.textContent = L.newFlow + ': ' + t.name;
        $epTheme.checked = false;
        selectedStateId = machine.initial;
        activeTab = 'embeds';
        $listView.style.display    = 'none';
        $builderView.style.display = 'flex';
        renderCanvas();
        renderInspector();
        lucide.createIcons();
      }
      if (exportBtn) {
        const t = savedTemplates.find(function(x) { return x._id === exportBtn.dataset.id; });
        if (!t) return;
        const blob = new Blob(
          [JSON.stringify({ name: t.name, description: t.description, machine: t.machine }, null, 2)],
          { type: 'application/json' }
        );
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = t.name.replace(/[^\w\s-]/g, '').trim().replace(/\s+/g, '_').toLowerCase() + '_template.json';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(a.href);
      }
      if (delBtn) {
        const id = delBtn.dataset.id;
        const t  = savedTemplates.find(function(x) { return x._id === id; });
        if (!t) return;
        if (!confirm('<%= t.embeds.jsConfirmDelTpl %> ' + t.name + '?')) return;
        api('DELETE', '/templates/' + id).then(function() {
          savedTemplates = savedTemplates.filter(function(x) { return x._id !== id; });
          renderTemplates();
          toast('<%= t.embeds.jsTplDeleted %>', 'success');
        }).catch(function(err) { toast(err.message, 'error'); });
      }
    });

    document.getElementById('btnOpenTemplates').addEventListener('click', openTemplatesDrawer);
    document.getElementById('btnCloseTplDrawer').addEventListener('click', closeTemplatesDrawer);
    document.getElementById('tplBackdrop').addEventListener('click', closeTemplatesDrawer);

    document.getElementById('btnTplImport').addEventListener('click', function() {
      document.getElementById('tplFileInput').click();
    });
    document.getElementById('tplFileInput').addEventListener('change', function() {
      const file = this.files[0];
      if (!file) return;
      const self = this;
      const reader = new FileReader();
      reader.onload = function(ev) {
        try {
          const data = JSON.parse(ev.target.result);
          const m = data.machine || data;
          if (!m.states || !m.initial) throw new Error('Missing "states" or "initial"');
          _pendingTplMachine = m;
          document.getElementById('tplSaveName').value = data.name || file.name.replace(/\.json$/i, '');
          document.getElementById('tplSaveDesc').value  = data.description || '';
          document.getElementById('tplSaveModal').classList.add('open');
          lucide.createIcons();
        } catch (err) {
          toast('<%= t.embeds.jsInvalidJSON %> ' + err.message, 'error');
        }
      };
      reader.readAsText(file);
      self.value = '';
    });

    document.getElementById('btnSaveAsTemplate').addEventListener('click', function() {
      if (!machine || !machine.initial || !Object.keys(machine.states || {}).length) {
        toast('<%= t.embeds.jsBuildFirst %>', 'error');
        return;
      }
      _pendingTplMachine = JSON.parse(JSON.stringify(machine));
      const title = $builderTitle.textContent || '';
      document.getElementById('tplSaveName').value = title.replace(/^[^:]+:\s*/, '') || '';
      document.getElementById('tplSaveDesc').value  = '';
      document.getElementById('tplSaveModal').classList.add('open');
      lucide.createIcons();
    });

    document.getElementById('tplSaveCancel').addEventListener('click', function() {
      document.getElementById('tplSaveModal').classList.remove('open');
      _pendingTplMachine = null;
    });
    document.getElementById('tplSaveModal').addEventListener('click', function(e) {
      if (e.target === this) {
        this.classList.remove('open');
        _pendingTplMachine = null;
      }
    });

    document.getElementById('tplSaveConfirm').addEventListener('click', async function() {
      const name = document.getElementById('tplSaveName').value.trim();
      if (!name) { document.getElementById('tplSaveName').focus(); return; }
      const desc = document.getElementById('tplSaveDesc').value.trim();
      const m    = _pendingTplMachine || JSON.parse(JSON.stringify(machine));
      this.disabled = true;
      const origHtml = this.innerHTML;
      this.textContent = '...';
      try {
        const r = await api('POST', '/templates', { name, description: desc, machine: m });
        savedTemplates.unshift(r.data);
        renderTemplates();
        document.getElementById('tplSaveModal').classList.remove('open');
        _pendingTplMachine = null;
        toast('<%= t.embeds.jsTplSaved %>', 'success');
      } catch (e) { toast(e.message, 'error'); }
      this.disabled = false;
      this.innerHTML = origHtml;
      lucide.createIcons();
    });

    /* ════════════════════════════════════════
       INIT
       ════════════════════════════════════════ */
    renderList();
    lucide.createIcons();

    // Auto-refresh the message grid when the AI agent saves an embed
    (function () {
      if (typeof io === 'undefined') return;
      const _aiSock = io();
      _aiSock.emit('join:guild', GUILD_ID);
      _aiSock.on('ai:embeds_updated', async function (data) {
        if (data && data.guildId && data.guildId !== GUILD_ID) return;
        try {
          const j = await api('GET', '/list');
          // Replace savedMessages in place so renderList() picks up the new data
          savedMessages.length = 0;
          (j.data || j.messages || []).forEach(m => savedMessages.push(m));
          renderList();
          lucide.createIcons();
        } catch (_) { /* silent — user can refresh manually */ }
      });
    }());

    // Canvas zoom / pan wiring
    $flowCanvas.addEventListener('wheel',      _onCanvasWheel,      { passive: false });
    $flowCanvas.addEventListener('mousedown',  _onCanvasPanStart);
    $flowCanvas.addEventListener('touchstart', _onCanvasTouchStart, { passive: false });
    $flowCanvas.addEventListener('touchmove',  _onCanvasTouchMove,  { passive: false });
    $flowCanvas.addEventListener('touchend',   _onCanvasTouchEnd);
    document.getElementById('btnZoomIn').addEventListener('click',    () => { _viewScale = Math.min(4, _viewScale * 1.2);  applyCanvasTransform(); });
    document.getElementById('btnZoomOut').addEventListener('click',   () => { _viewScale = Math.max(0.15, _viewScale / 1.2); applyCanvasTransform(); });
    document.getElementById('btnZoomReset').addEventListener('click', () => { _viewOX = 0; _viewOY = 0; _viewScale = 1; applyCanvasTransform(); });
    document.getElementById('btnZoomLock').addEventListener('click', () => {
      _zoomLocked = !_zoomLocked;
      const btn = document.getElementById('btnZoomLock');
      btn.classList.toggle('locked', _zoomLocked);
      btn.title = _zoomLocked ? 'Unlock zoom' : 'Lock zoom';
      btn.innerHTML = _zoomLocked
        ? '<i data-lucide="lock" style="width:11px;height:11px;"></i>'
        : '<i data-lucide="lock-open" style="width:11px;height:11px;"></i>';
      lucide.createIcons();
    });
    document.getElementById('btnAutoLayout').addEventListener('click', autoLayout);
    applyCanvasTransform();

    /* ── Standard page JS ── */
    const openProf  = document.getElementById('open-profile');
    const closeProf = document.getElementById('close-profile');
    const profSide  = document.getElementById('prof-sidebar');
    const profBack  = document.getElementById('prof-backdrop');
    if (openProf && profSide) {
      openProf.addEventListener('click', () => { profSide.classList.add('open'); profBack && profBack.classList.add('show'); profSide.removeAttribute('aria-hidden'); });
      [closeProf, profBack].forEach(el => el && el.addEventListener('click', () => { profSide.classList.remove('open'); profBack && profBack.classList.remove('show'); profSide.setAttribute('aria-hidden', 'true'); }));
    }
    const menuToggle  = document.getElementById('menu-toggle');
    const navOverlay  = document.getElementById('nav-overlay');
    const navSidebar  = document.querySelector('.nav-sidebar');
    const mgmtSidebar = document.getElementById('mgmt-sidebar');
    if (menuToggle) menuToggle.addEventListener('click', () => {
      if (mgmtSidebar?.classList.contains('open')) { mgmtSidebar.classList.remove('open'); navOverlay?.classList.remove('open'); }
      else { mgmtSidebar?.classList.add('open'); navOverlay?.classList.add('open'); }
    });
    if (navOverlay) navOverlay.addEventListener('click', () => {
      mgmtSidebar?.classList.remove('open');
      navSidebar?.classList.remove('open');
      navOverlay.classList.remove('open');
    });
    const copyIdRow = document.getElementById('prof-copy-id');
    if (copyIdRow) copyIdRow.addEventListener('click', () => {
      navigator.clipboard.writeText(copyIdRow.dataset.uid || '').catch(() => {});
      const lbl = document.getElementById('prof-copy-label');
      if (lbl) { const orig = lbl.textContent; lbl.textContent = '<%= t.embeds.jsCopied %>'; setTimeout(() => lbl.textContent = orig, 1500); }
    });
    /* Language switcher */
    const langSelectEl = document.getElementById('lang-select');
    if (langSelectEl) {
      langSelectEl.addEventListener('change', function () {
        const u = new URL(window.location.href);
        u.searchParams.set('lang', this.value);
        window.location.href = u.toString();
      });
    }
    document.querySelectorAll('.mgmt-section-btn').forEach(btn =>
      btn.addEventListener('click', () => { const body = btn.nextElementSibling; btn.classList.toggle('open'); if (body) body.classList.toggle('open'); }));
    document.querySelectorAll('.nav-link').forEach(a => a.addEventListener('click', e => {
      const href = a.getAttribute('href');
      if (!href || href.startsWith('#') || href.startsWith('javascript')) return;
      e.preventDefault();
      const ov = document.getElementById('ov');
      if (ov) { ov.style.animation = 'pOut .35s cubic-bezier(.4,0,.2,1) forwards'; ov.style.pointerEvents = 'all'; }
      setTimeout(() => { window.location.href = href; }, 340);
    }));

  })();
  </script>
