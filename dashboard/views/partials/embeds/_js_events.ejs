       INSPECTOR EVENTS (static bindings)
       ════════════════════════════════════════ */
    $inspLabel.addEventListener('input', () => {
      const s = getSelectedState(); if (!s) return;
      s.label = $inspLabel.value;
      const c = document.getElementById('sc_' + selectedStateId);
      if (c) { const lbl = c.querySelector('.flow-state-lbl'); if (lbl) lbl.textContent = s.label; }
    });
    $inspColor.addEventListener('input', () => {
      const s = getSelectedState(); if (!s) return;
      s.color = $inspColor.value;
      document.querySelectorAll('.color-swatch').forEach(el => el.classList.toggle('active', el.dataset.color === s.color));
      const c = document.getElementById('sc_' + selectedStateId);
      if (c) { const dot = c.querySelector('.flow-state-dot'); if (dot) dot.style.background = s.color; }
    });
    // Color theme swatches
    document.getElementById('colorSwatches').addEventListener('click', e => {
      const sw = e.target.closest('.color-swatch'); if (!sw) return;
      const s = getSelectedState(); if (!s) return;
      s.color = sw.dataset.color;
      $inspColor.value = s.color;
      document.querySelectorAll('.color-swatch').forEach(el => el.classList.toggle('active', el.dataset.color === s.color));
      const c = document.getElementById('sc_' + selectedStateId);
      if (c) { const dot = c.querySelector('.flow-state-dot'); if (dot) dot.style.background = s.color; }
    });
    document.getElementById('btnDelMulti').addEventListener('click', deleteSelectedState);
    $inspSetInit.addEventListener('click', () => { if (selectedStateId) setInitialState(selectedStateId); });
    $inspDelState.addEventListener('click', () => deleteSelectedState());
    document.getElementById('btnCopyState').addEventListener('click', copySelectedState);
    document.querySelectorAll('.insp-tab').forEach(tab => tab.addEventListener('click', function () {
      activeTab = this.dataset.tab;
      renderActiveTab();
      lucide.createIcons();
    }));

    // Preview toggle (starts collapsed — user opens it when needed)
    document.getElementById('previewToggleBar').addEventListener('click', () => {
      document.getElementById('previewWrap').classList.toggle('collapsed');
    });
    document.getElementById('btnAddState').addEventListener('click', addState);
    document.getElementById('btnAddStateEmpty').addEventListener('click', addState);
    document.getElementById('btnAddGroup').addEventListener('click', addGroup);
    document.getElementById('btnBack').addEventListener('click', closeEditor);
    document.getElementById('btnUndo').addEventListener('click', undoAction);
    document.getElementById('btnRedo').addEventListener('click', redoAction);
    document.getElementById('btnDelGroup').addEventListener('click', deleteSelectedGroup);
    document.getElementById('inspGroupLabel').addEventListener('input', syncGroupFromDOM);
    document.getElementById('inspGroupColor').addEventListener('input', syncGroupFromDOM);
    _initCanvasDelegation();
    window.addEventListener('beforeunload', e => { if (_isDirty) { e.preventDefault(); e.returnValue = ''; } });
    document.addEventListener('keydown', e => {
      if ($builderView.style.display === 'none') return;
      if ((e.key === 'Delete' || e.key === 'Backspace') && (_multiSel.size > 1 || selectedStateId) && !e.target.matches('input,textarea,select,[contenteditable]')) {
        e.preventDefault(); deleteSelectedState(); return;
      }
      // Arrow-key nudge: move selected state on the canvas (Shift = 50 px, plain = 10 px)
      if (['ArrowLeft','ArrowRight','ArrowUp','ArrowDown'].includes(e.key)
          && selectedStateId && !e.target.matches('input,textarea,select,[contenteditable]')) {
        e.preventDefault();
        const _step = e.shiftKey ? 50 : 10;
        const _ks   = machine.states[selectedStateId]; if (!_ks) return;
        const _p    = _ks.position || { x: 80, y: 80 };
        if      (e.key === 'ArrowLeft')  _p.x = Math.max(0, _p.x - _step);
        else if (e.key === 'ArrowRight') _p.x += _step;
        else if (e.key === 'ArrowUp')    _p.y = Math.max(0, _p.y - _step);
        else if (e.key === 'ArrowDown')  _p.y += _step;
        _ks.position = _p;
        const _kc = document.getElementById('sc_' + selectedStateId);
        if (_kc) { _kc.style.left = _p.x + 'px'; _kc.style.top = _p.y + 'px'; }
        updateArrows(); scheduleMinimapUpdate(); markDirty(); return;
      }
      if (!(e.ctrlKey || e.metaKey)) return;
      if (e.key === 'z' && !e.shiftKey)                          { e.preventDefault(); undoAction(); }
      else if (e.key === 'y' || (e.key === 'z' && e.shiftKey))  { e.preventDefault(); redoAction(); }
      else if (e.key === 'c' && selectedStateId)                 { e.preventDefault(); copySelectedState(); }
      else if (e.key === 'v')                                    { e.preventDefault(); pasteState(); }
    });
    document.getElementById('btnNewMessage').addEventListener('click', () => openEditor(null));
    $epTheme.addEventListener('change',   () => { epTheme   = $epTheme.checked; });
    $multiUser.addEventListener('change', () => { multiUser = $multiUser.checked; });

    /* ── Smart Triggers modal events ── */
    const $triggersModal = document.getElementById('triggersModal');
    document.getElementById('btnTriggers').addEventListener('click', () => {
      if (!machine.triggers) machine.triggers = [];
      renderTriggersModal();
      updateTriggersCountBadge();
      $triggersModal.classList.add('open');
      lucide.createIcons();
    });
    document.getElementById('btnCloseTriggersModal').addEventListener('click', () => {
      $triggersModal.classList.remove('open');
      updateTriggersCountBadge();
    });
    $triggersModal.addEventListener('click', e => {
      if (e.target === $triggersModal) $triggersModal.classList.remove('open');
    });
    document.getElementById('btnAddTrigger').addEventListener('click', () => {
      if (!machine.triggers) machine.triggers = [];
      machine.triggers.push({
        id: nid('trg'), type: 'cron', enabled: true,
        schedule: '0 9 * * *', channelOverride: '',
        targetState: machine.initial || '', actions: ['send_to_channel'],
      });
      renderTriggersModal();
      updateTriggersCountBadge();
    });
    document.getElementById('btnSaveTriggers').addEventListener('click', async () => {
      if (!currentDoc) {
        toast('<%= t.embeds.jsSaveFirst %>', 'error');
        return;
      }
      const btn = document.getElementById('btnSaveTriggers');
      btn.disabled = true;
      const prev = btn.innerHTML;
      btn.innerHTML = '<i data-lucide="loader" style="width:13px;height:13px;"></i> <%= t.embeds.jsSaving %>';
      try {
        const result = await api('POST', '/save', {
          _id:       currentDoc._id,
          name:      currentDoc.name,
          channelId: currentDoc.channelId,
          epTheme,
          machine:   Object.assign({}, machine, { multiUser: multiUser || undefined }),
        });
        toast('<%= t.embeds.jsTriggersSaved %>', 'success');
        // Sync the local machine triggers so inspector stays up-to-date
        if (result.data) {
          currentDoc = result.data;
          const idx = savedMessages.findIndex(m => m._id === currentDoc._id);
          if (idx >= 0) savedMessages[idx] = currentDoc;
        }
        $triggersModal.classList.remove('open');
      } catch (e) {
        toast(e.message, 'error');
      }
      btn.disabled = false;
      btn.innerHTML = prev;
      lucide.createIcons();
    });

    /* ════════════════════════════════════════
       SAVE
       ════════════════════════════════════════ */
    const $sendModeGroup = document.getElementById('sendModeGroup');
    const $modeEdit      = document.getElementById('modeEdit');
    const $modeNew       = document.getElementById('modeNew');

    document.getElementById('btnSave').addEventListener('click', () => {
      const _valIssues = validateFlow();
      if (_valIssues.length && !confirm('<%= t.embeds.jsWarnBefore %>\n' + _valIssues.map(x => '• ' + x).join('\n') + '\n\n<%= t.embeds.jsContinueAnyway %>')) return;
      const isEdit = !!(currentDoc?.messageId);
      // Update modal title and description based on context
      document.getElementById('saveModalTitle').textContent = currentDoc
        ? '<%= t.embeds.jsSaveChanges %>'
        : '<%= t.embeds.jsNewMessage %>';
      document.getElementById('saveModalDesc').textContent = currentDoc
        ? '<%= t.embeds.jsUpdateDesc %>'
        : '<%= t.embeds.saveModalDesc %>';
      $modalSave.textContent = isEdit
        ? '<%= t.embeds.jsSaveAndUpdate %>'
        : '<%= t.embeds.btnSaveAndSend %>';
      if (currentDoc) {
        $modalName.value    = currentDoc.name || '';
        $modalChannel.value = currentDoc.channelId || '';
        $modeEdit.checked   = !!currentDoc.messageId;
        $modeNew.checked    = !currentDoc.messageId;
      } else {
        $modalName.value    = '';
        $modalChannel.value = '';
        $modeNew.checked    = true;
      }
      $sendModeGroup.classList.add('visible');
      lucide.createIcons();
      validateModal();
      $saveModal.classList.add('open');
    });
    function validateModal() { $modalSave.disabled = !($modalName.value.trim() && $modalChannel.value); }
    $modalName.addEventListener('input', validateModal);
    $modalChannel.addEventListener('change', validateModal);
    $modalCancel.addEventListener('click', () => $saveModal.classList.remove('open'));
    $saveModal.addEventListener('click', e => { if (e.target === $saveModal) $saveModal.classList.remove('open'); });
    $modalSave.addEventListener('click', async () => {
      $modalSave.disabled = true;
      $modalSave.textContent = '<%= t.embeds.jsSaving %>';
      epTheme   = $epTheme.checked;
      multiUser = $multiUser.checked;
      const forceNew = $modeNew.checked;
      // Clone machine to avoid mutating shared state (especially if save fails)
      const machineCopy = JSON.parse(JSON.stringify(machine));
      machineCopy.multiUser = multiUser || undefined;
      const payload = {
        _id:      currentDoc ? currentDoc._id : undefined,
        name:     $modalName.value.trim(),
        channelId:$modalChannel.value,
        epTheme,
        machine:  machineCopy,
        forceNew: forceNew || undefined,
      };
      try {
        const result = await api('POST', '/save', payload);
        $saveModal.classList.remove('open');
        toast(L.saved, 'success');
        clearDirty();
        if (currentDoc) {
          const idx = savedMessages.findIndex(m => m._id === currentDoc._id);
          if (idx >= 0) savedMessages[idx] = result.data;
          currentDoc = result.data;
        } else {
          savedMessages.unshift(result.data);
          currentDoc = result.data;
        }
        $builderTitle.textContent = L.editFlow + ': ' + result.data.name;
      } catch (e) { toast(e.message, 'error'); }
      $modalSave.disabled = false;
      $modalSave.textContent = '<%= t.embeds.btnSaveAndSend %>';
    });

